# ── AI ───────────────────────────────────────────────────────────────────────
# Required: API key (works with OpenAI or any OpenAI-compatible provider)
OPENAI_API_KEY=sk-...

# Optional: override the model used for each AI call (default: gpt-4o-mini)
# AI_DIFFICULTY_MODEL=gpt-4o-mini
# AI_NARRATOR_MODEL=gpt-4o-mini

# Optional: embedding model for narrative impressions (default: text-embedding-3-small)
# AI_EMBEDDING_MODEL=text-embedding-3-small

# Optional: point to a different provider's OpenAI-compatible endpoint
# AI_BASE_URL=https://api.openai.com

# Optional: enable JSON response_format for providers that support it.
# Auto-detected for OpenAI. Set explicitly for others (e.g. DeepSeek).
# AI_JSON_MODE=true

# ── Example: Claude via OpenRouter ────────────────────────────────────────────
# OPENAI_API_KEY=sk-or-...
# AI_BASE_URL=https://openrouter.ai/api/v1
# AI_DIFFICULTY_MODEL=anthropic/claude-sonnet-4.6
# AI_NARRATOR_MODEL=anthropic/claude-sonnet-4.6

# ── Example: DeepSeek ────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# AI_BASE_URL=https://api.deepseek.com
# AI_DIFFICULTY_MODEL=deepseek-chat
# AI_NARRATOR_MODEL=deepseek-chat
# AI_JSON_MODE=true

# ── Database ─────────────────────────────────────────────────────────────────
# Local development typically uses peer auth (no host/password needed).
# Uncomment and fill in if connecting to a remote or password-protected instance.
# DB_HOST=localhost
# DB_USERNAME=postgres
# DB_PASSWORD=
# DB_NAME=liber_meus_v2_production

# ── Rails ───────────────────────────────────────────────────────────────────
# Required in production to decrypt credentials.yml.enc
# RAILS_MASTER_KEY=

# Log level (default: info in production)
# RAILS_LOG_LEVEL=info

# Puma configuration
# PORT=3000
# RAILS_MAX_THREADS=5
# SOLID_QUEUE_IN_PUMA=true

# ── Scenarios ──────────────────────────────────────────────────────────────────
# Optional: comma-separated list of scenario slugs to hide from the selection screen.
# Hidden scenarios are still playable via direct URL / existing games.
# HIDDEN_SCENARIOS=prison_break,romeo_juliet

# ── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Deployment (Kamal) ──────────────────────────────────────────────────────
# GITHUB_USERNAME=your-github-username
# DEPLOY_HOST=your-server-ip
# STAGING_HOST=your-staging-ip
# PRODUCTION_HOST=your-production-ip
# KAMAL_REGISTRY_PASSWORD=ghp_...
