<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || t("app.name") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="<%= t('app.name') %>">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Playfair+Display:ital,wght@0,700;1,400&family=Lora:ital,wght@0,400;1,400&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "base", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "game/layout", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "game/panels", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "game/turns", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "pages/scenario_select", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "pages/random_setup", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "pages/sessions", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "pages/dashboard", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <style>
      :root {
        --theme-bg: #0d0d0d;
        --theme-text: #c8c8b4;
        --theme-accent: #8ab4a0;
        --theme-font: 'Courier New', Courier, monospace;
        --theme-bg-image: none;
      }
    </style>

    <%= yield :head %>
  </head>

  <body>
    <div class="container">
      <% if current_user && controller_name != "sessions" %>
        <nav class="app-nav">
          <span class="app-nav-user"><%= current_user.name || current_user.email %></span>
          <%= button_to t("views.sessions.sign_out", default: "Sign out"), sign_out_path, method: :delete, class: "app-nav-signout" %>
        </nav>
      <% end %>
      <% if notice %>
        <div class="flash-notice"><%= notice %></div>
      <% end %>
      <% if alert %>
        <div class="flash-alert"><%= alert %></div>
      <% end %>
      <div id="flash"></div>
      <%= yield %>
    </div>
  </body>
</html>
