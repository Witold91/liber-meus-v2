<% content_for :title, t("views.random_setup.step2_title", default: "Random Adventure — Describe Your Hero") %>

<% content_for :head do %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Playfair+Display:ital,wght@0,700;1,400&family=Lora:ital,wght@0,400;1,400&display=swap" rel="stylesheet">
<% end %>

<div class="setup-header">
  <h1><%= t("views.random_setup.heading", default: "Random Adventure") %></h1>
  <p><%= t("views.random_setup.subtitle_hero", default: "Your world awaits. Now, who are you?") %></p>
</div>

<div class="setup-card">
  <div class="setup-step"><%= t("views.random_setup.step", default: "Step %{n} of 3", n: 2) %></div>

  <div class="generated-preview">
    <h3><%= @world_data&.dig("setting_name") || "Your World" %></h3>
    <p><%= @world_data&.dig("world_context_display") || @world_data&.dig("world_context") %></p>
  </div>

  <%= form_with url: create_hero_random_setup_path, method: :post do |f| %>
    <div style="margin-bottom: 1rem;">
      <%= f.label :hero_description, t("views.random_setup.hero_label", default: "Describe your hero") %>
      <%= f.text_area :hero_description,
            placeholder: t("views.random_setup.hero_placeholder", default: "A grizzled old smuggler with a quick wit and a faster draw, haunted by a deal gone wrong..."),
            autofocus: true %>
    </div>

    <div class="setup-form-row">
      <%= f.submit t("views.random_setup.generate_hero", default: "Generate Hero"), class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
