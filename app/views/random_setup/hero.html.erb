<% content_for :title, t("views.random_setup.step3_title", default: "Random Adventure — Confirm & Begin") %>

<% content_for :head do %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Playfair+Display:ital,wght@0,700;1,400&family=Lora:ital,wght@0,400;1,400&display=swap" rel="stylesheet">
<% end %>

<div class="setup-header">
  <h1><%= t("views.random_setup.heading", default: "Random Adventure") %></h1>
  <p><%= t("views.random_setup.subtitle_confirm", default: "All is set. Begin when you are ready.") %></p>
</div>

<div class="setup-card">
  <div class="setup-step"><%= t("views.random_setup.step", default: "Step %{n} of 3", n: 3) %></div>

  <div class="generated-preview">
    <h3><%= @world_data&.dig("setting_name") || "Your World" %></h3>
    <p><%= @world_data&.dig("world_context_display") || @world_data&.dig("world_context") %></p>
  </div>

  <div class="generated-preview">
    <div class="hero-name"><%= @hero_data&.dig("name") || "Your Hero" %></div>
    <p><%= @hero_data&.dig("description_display") || @hero_data&.dig("description") %></p>

    <% if @hero_data&.dig("starting_equipment")&.any? %>
      <div class="equipment-list">
        <div class="equipment-label"><%= t("views.random_setup.starting_equipment", default: "Starting Equipment") %></div>
        <% @hero_data["starting_equipment"].each do |item| %>
          <div class="equipment-item">
            <span class="item-name"><%= item["name"] %></span>
            <span class="item-status"> — <%= item["status"] %></span>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <%= form_with url: create_game_random_setup_path, method: :post do |f| %>
    <div class="setup-form-row">
      <%= link_to t("views.random_setup.start_over", default: "Start over"), new_random_setup_path, style: "color: #5a4e3a; font-family: 'Lora', serif; font-size: 0.82rem;" %>
      <%= f.submit t("views.random_setup.begin_adventure", default: "Begin Adventure"), class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
