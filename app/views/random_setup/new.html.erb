<% content_for :title, t("views.random_setup.step1_title", default: "Random Adventure — Describe Your World") %>

<% content_for :head do %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Playfair+Display:ital,wght@0,700;1,400&family=Lora:ital,wght@0,400;1,400&display=swap" rel="stylesheet">
<% end %>

<div class="setup-header">
  <h1><%= t("views.random_setup.heading", default: "Random Adventure") %></h1>
  <p><%= t("views.random_setup.subtitle", default: "Describe a world, and it shall be conjured for you.") %></p>
</div>

<div class="setup-card">
  <div class="setup-step"><%= t("views.random_setup.step", default: "Step %{n} of 3", n: 1) %></div>

  <%= form_with url: create_setting_random_setup_path, method: :post do |f| %>
    <div style="margin-bottom: 1rem;">
      <%= f.label :setting_description, t("views.random_setup.setting_label", default: "Describe your world") %>
      <%= f.text_area :setting_description,
            placeholder: t("views.random_setup.setting_placeholder", default: "A sprawling space station on the edge of the galaxy, where smugglers and bounty hunters mingle in neon-lit corridors..."),
            autofocus: true %>
    </div>

    <div class="setup-form-row">
      <div>
        <%= f.label :game_language, t("views.scenario_select.language_label", default: "Language") %>
        <%= f.select :game_language, I18n.available_locales.map { |locale| [t("languages.#{locale}", default: locale.to_s), locale] }, { selected: I18n.locale } %>
      </div>
      <%= f.submit t("views.random_setup.generate_world", default: "Generate World"), class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
