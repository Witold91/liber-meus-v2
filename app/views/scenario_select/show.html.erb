<% content_for :title, t("app.titles.scenario_select", app_name: t("app.name")) %>

<% content_for :head do %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Playfair+Display:ital,wght@0,700;1,400&family=Lora:ital,wght@0,400;1,400&display=swap" rel="stylesheet">
<% end %>

<div class="scenario-header">
  <h1><%= t("views.scenario_select.heading") %></h1>
  <p><%= t("views.scenario_select.subtitle") %></p>
</div>

<div class="scenario-grid">
  <% @scenarios.each do |scenario| %>
    <div class="scenario-card">
      <h2 style="color: <%= scenario.dig('theme', 'accent_color') || '#8ab4a0' %>;"><%= scenario["title"] %></h2>
      <p><%= scenario["description"] %></p>
      <%= form_with url: scenario_select_path, method: :post do |f| %>
        <%= f.hidden_field :scenario_slug, value: scenario["slug"] %>
        <div class="scenario-form">
          <div>
            <%= f.label :game_language, t("views.scenario_select.language_label") %>
            <%= f.select :game_language, I18n.available_locales.map { |locale| [t("languages.#{locale}"), locale] }, { selected: I18n.locale } %>
          </div>
          <%= f.submit t("views.scenario_select.begin"), class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="scenario-card">
    <h2 style="color: #c8a86e;"><%= t("views.random_setup.card_title", default: "Random Adventure") %></h2>
    <p><%= t("views.random_setup.card_description", default: "Describe any world you can imagine. AI will generate the setting, scenes, and characters. No script — pure exploration.") %></p>
    <div class="scenario-form">
      <%= link_to t("views.random_setup.card_begin", default: "Create World"), new_random_setup_path, class: "btn btn-primary" %>
    </div>
  </div>
</div>
